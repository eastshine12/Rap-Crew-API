<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.eastshine.rapcrew.dao.CardDAO">

	<select id="selectCard" parameterType="Card" resultType="Card">
        SELECT * 
        FROM TB_CARD
        WHERE cardId = #{cardId}
    </select>


</mapper>